---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { formatDate, postDescription, readingMinutes, getRelatedPosts, displayTitle, type Post } from "@lib/posts";
import { SITE } from "@lib/site";

interface Props { post: Post; readMin?: number }
const { post, readMin = 3 } = Astro.props;
const { date, featuredImage, featuredImageAlt } = post.data;
const title = displayTitle(post);
const related = await getRelatedPosts(post, 3);
const desc = postDescription(post);

const jsonld = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  datePublished: date.toISOString(),
  description: desc,
  image: featuredImage ? new URL(featuredImage, SITE.url).href : undefined,
  author: { "@type": "Organization", name: SITE.name },
  publisher: { "@type": "Organization", name: SITE.name },
  mainEntityOfPage: new URL(`/${post.id}/`, SITE.url).href,
};
---
<BaseLayout title={post.data.metaTitle || title} description={desc} type="article" image={featuredImage}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} is:inline />
  <article>
    <Container class="max-w-3xl pt-(--spacing-section)">
      <nav class="text-sm text-slate-500"><a href="/blog/" class="hover:text-blue-700">Studiegids</a> <span class="mx-1">/</span> <span class="text-slate-700">{title}</span></nav>
      <h1 class="mt-3 border-l-4 border-blue-700 pl-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{title}</h1>
      <div class="mt-3 flex items-center gap-3 text-sm text-slate-500">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        <span aria-hidden>·</span>
        <span>{readMin} min lezen</span>
      </div>
    </Container>

    {featuredImage && (
      <Container class="max-w-4xl">
        <img src={featuredImage} alt={featuredImageAlt || title} width="1200" height="630"
             loading="eager" fetchpriority="high" decoding="sync"
             class="mt-6 aspect-[16/9] w-full rounded-2xl object-cover" />
      </Container>
    )}

    <Container class="max-w-3xl">
      <div class="rounded-xl bg-blue-50 border border-blue-200 p-5 my-8 flex items-start gap-3">
        <div class="shrink-0 w-1 self-stretch rounded-full bg-blue-600"></div>
        <div>
          <p class="text-sm font-semibold text-blue-800 mb-1">Snel je rijbewijs halen?</p>
          <p class="text-sm text-blue-700">Bekijk onze <a href="/blog/" class="underline font-medium">studiegids</a> met alle theorie en examentips op een rij.</p>
        </div>
      </div>
      <div class="article-prose pb-(--spacing-section)">
        <slot />
      </div>
    </Container>
  </article>

  {related.length > 0 && (
    <section class="border-t border-slate-200 bg-slate-50">
      <Container class="py-(--spacing-section)">
        <h2 class="text-2xl font-extrabold text-slate-900">Meer uit de studiegids</h2>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((p) => <BlogPostCard post={p} />)}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>
