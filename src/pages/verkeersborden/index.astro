---
<BaseLayout
  title="Alle Nederlandse verkeersborden — overzicht per categorie | GratisVerkeersbordenOefening"
  description="Compleet overzicht van alle Nederlandse verkeersborden per categorie: gevaar, voorrang, verbod, gebod, aanwijzing en informatie."
>
  <div class="bg-green-700 text-white">
    <Container class="py-14">
      <h1 class="text-4xl font-black tracking-tight">Alle verkeersborden</h1>
      <p class="mt-3 text-green-100 max-w-xl">Compleet overzicht per categorie — van A (gevaarswaarschuwing) tot F (informatie).</p>
    </Container>
  </div>

  <!-- Category jump nav -->
  <div class="sticky top-14 z-40 bg-white border-b border-gray-100 shadow-sm">
    <Container class="py-2">
      <nav class="flex gap-2 overflow-x-auto scrollbar-none text-xs font-semibold">
        {categories.map((c) => (
          <a href={`#${c.id}`} class="shrink-0 px-3 py-1.5 rounded-full border border-gray-200 text-gray-600 hover:border-green-400 hover:text-green-700 transition-colors whitespace-nowrap">
            {c.code} — {c.title.replace('borden', '').trim()}
          </a>
        ))}
      </nav>
    </Container>
  </div>

  <Container class="py-(--spacing-section) space-y-16">
    {categories.map((cat) => (
      <section id={cat.id} class={`rounded-2xl border-2 ${cat.accent} overflow-hidden`}>
        <div class="px-6 py-5 border-b border-current/10">
          <div class="flex items-center gap-3">
            <span class={`text-xs font-black uppercase tracking-widest ${cat.heading}`}>Categorie {cat.code}</span>
            <span class="text-gray-300">|</span>
            <span class="text-xs text-gray-400">{cat.kleur}</span>
          </div>
          <h2 class={`text-2xl font-black mt-1 ${cat.heading}`}>{cat.title}</h2>
        </div>
        <div class="p-6">
          <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
            {cat.borden.map((b) => (
              <div class="flex items-center gap-3 bg-white rounded-xl px-4 py-2.5 border border-white/80 shadow-sm">
                <span class={`text-xs font-black ${cat.heading} shrink-0 w-10`}>{b.nr}</span>
                <span class="text-sm text-gray-700">{b.naam}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}
  </Container>

  <section class="bg-green-700 text-white">
    <Container class="py-12 text-center">
      <h2 class="text-2xl font-black mb-3">Klaar om te oefenen?</h2>
      <p class="text-green-100 text-sm mb-6">Nu je alle categorieën kent, ga oefenen en test je kennis.</p>
      <a href="/oefenen/" class="inline-flex items-center bg-amber-400 text-gray-900 font-black px-7 py-3 rounded-full hover:bg-amber-300 transition-colors text-sm">
        Oefentips bekijken →
      </a>
    </Container>
  </section>
</BaseLayout>
