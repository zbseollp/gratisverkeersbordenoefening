---
<BaseLayout
  title="Alle Nederlandse verkeersborden — overzicht per categorie | GratisVerkeersbordenOefening"
  description="Compleet overzicht van alle Nederlandse verkeersborden per categorie: gevaar, voorrang, verbod, gebod, aanwijzing en informatie."
>
  <!-- Page header: dark -->
  <div class="bg-zinc-950 text-white">
    <Container class="py-12">
      <span class="text-xs font-black uppercase tracking-widest text-yellow-400 mb-3 block">Referentie</span>
      <h1 class="text-4xl font-black tracking-tight">Alle verkeersborden</h1>
      <p class="mt-3 text-zinc-400 max-w-xl">Compleet overzicht per categorie — van A (gevaarswaarschuwing) tot F (informatie).</p>
    </Container>
  </div>

  <!-- Sticky category jump nav: dark bar -->
  <div class="sticky top-14 z-40 bg-zinc-900 border-b border-zinc-700">
    <Container class="py-0">
      <nav class="flex gap-0 overflow-x-auto scrollbar-none">
        {categories.map((c) => (
          <a href={`#${c.id}`} class="shrink-0 px-4 py-3 text-xs font-black text-zinc-400 hover:text-yellow-400 hover:bg-zinc-800 transition-colors whitespace-nowrap border-r border-zinc-700 last:border-r-0">
            <span class={`${c.symbolColor} mr-1`}>{c.symbol}</span> {c.code}
          </a>
        ))}
      </nav>
    </Container>
  </div>

  <!-- Category sections: list style, not card grid -->
  <Container class="py-(--spacing-section) space-y-14">
    {categories.map((cat) => (
      <section id={cat.id}>
        <!-- Category header -->
        <div class="flex items-center gap-4 mb-0 border-b-2 border-zinc-950 pb-4">
          <div class="w-12 h-12 bg-zinc-950 flex items-center justify-center shrink-0">
            <span class={`text-xl leading-none ${cat.symbolColor}`}>{cat.symbol}</span>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <span class="text-xs font-black uppercase tracking-widest text-zinc-400">Categorie {cat.code}</span>
              <span class="text-xs text-zinc-300 hidden sm:block">· {cat.kleur}</span>
            </div>
            <h2 class="text-2xl font-black text-zinc-950">{cat.title}</h2>
          </div>
        </div>

        <!-- Signs: compact list rows -->
        <div class="divide-y divide-zinc-100">
          {cat.borden.map((b, i) => (
            <div class:list={["flex items-center gap-4 py-3 px-2", i % 2 === 0 ? "" : "bg-zinc-50/60"]}>
              <span class="font-black text-xs text-zinc-400 w-10 shrink-0 font-mono">{b.nr}</span>
              <span class="text-sm text-zinc-800">{b.naam}</span>
            </div>
          ))}
        </div>
      </section>
    ))}
  </Container>

  <!-- CTA: yellow band -->
  <section class="bg-yellow-400">
    <Container class="py-12 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-xs font-black uppercase tracking-widest text-yellow-700 mb-1">Nu je de borden kent</p>
        <h2 class="text-2xl font-black text-zinc-900">Klaar om te oefenen?</h2>
        <p class="text-zinc-700 text-sm mt-1">Lees de oefenstrategie en slaag voor je theorie-examen.</p>
      </div>
      <a href="/oefenen/" class="shrink-0 inline-flex items-center bg-zinc-950 text-yellow-400 font-black px-7 py-3 hover:bg-zinc-800 transition-colors text-sm">
        Oefentips bekijken →
      </a>
    </Container>
  </section>
</BaseLayout>
