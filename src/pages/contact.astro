---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
const ACCESS_KEY = import.meta.env.WEB3FORMS_ACCESS_KEY || "8ea4e1a2-67ac-4af4-a4f3-f65d5ae539e1";
---
<BaseLayout
  title="Contact | GratisVerkeersbordenOefening"
  description="Vragen of opmerkingen over GratisVerkeersbordenOefening? Neem contact op."
>
  <div class="bg-zinc-950 text-white">
    <Container class="py-12">
      <span class="text-xs font-black uppercase tracking-widest text-yellow-400 mb-3 block">Contact</span>
      <h1 class="text-4xl font-black tracking-tight">Stuur ons een bericht</h1>
      <p class="mt-2 text-zinc-400">Een vraag, tip of foutmelding? We lezen elk bericht.</p>
    </Container>
  </div>

  <Container class="max-w-2xl py-(--spacing-section)">
    <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5 border border-zinc-200 p-6 sm:p-8">
      <input type="hidden" name="access_key" value={ACCESS_KEY} />
      <input type="hidden" name="subject" value="Nieuw bericht via GratisVerkeersbordenOefening" />
      <input type="hidden" name="from_name" value="GratisVerkeersbordenOefening" />
      <input type="hidden" name="redirect" data-redirect value="https://gratisverkeersbordenoefening.nl/contact/thanks/" />
      <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div>
        <label for="name" class="block text-sm font-bold text-zinc-800 mb-1">Naam</label>
        <input id="name" name="name" required class="w-full border border-zinc-300 px-4 py-2.5 text-sm focus:border-yellow-400 focus:outline-none focus:ring-2 focus:ring-yellow-100" />
      </div>
      <div>
        <label for="email" class="block text-sm font-bold text-zinc-800 mb-1">E-mailadres</label>
        <input id="email" type="email" name="email" required class="w-full border border-zinc-300 px-4 py-2.5 text-sm focus:border-yellow-400 focus:outline-none focus:ring-2 focus:ring-yellow-100" />
      </div>
      <div>
        <label for="message" class="block text-sm font-bold text-zinc-800 mb-1">Bericht</label>
        <textarea id="message" name="message" rows="5" required minlength="10" class="w-full border border-zinc-300 px-4 py-2.5 text-sm focus:border-yellow-400 focus:outline-none focus:ring-2 focus:ring-yellow-100"></textarea>
      </div>
      <div class="h-captcha" data-captcha="true"></div>

      <button type="submit" class="inline-flex items-center bg-zinc-950 text-yellow-400 font-black px-7 py-3 text-sm hover:bg-zinc-800 transition-colors">Versturen →</button>
      <p class="text-xs text-zinc-400">We gebruiken je gegevens alleen om je bericht te beantwoorden. Beschermd met hCaptcha.</p>
    </form>
  </Container>

  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    if (form) {
      const redirect = form.querySelector("[data-redirect]") as HTMLInputElement | null;
      if (redirect) redirect.value = window.location.origin + "/contact/thanks/";
      let loaded = false;
      const load = () => {
        if (loaded) return; loaded = true;
        const s = document.createElement("script");
        s.src = "https://web3forms.com/client/script.js"; s.async = true; s.defer = true;
        document.head.appendChild(s);
      };
      form.addEventListener("focusin", load, { once: true });
      form.addEventListener("submit", load);
    }
  </script>
</BaseLayout>
