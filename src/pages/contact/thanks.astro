---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
---
<BaseLayout title="Bedankt voor je bericht | GratisVerkeersbordenOefening" description="Je bericht is verstuurd." noindex={true}>
  <Container class="max-w-2xl py-(--spacing-section) text-center">
    <div class="mx-auto grid h-16 w-16 place-items-center bg-yellow-400 text-zinc-900 text-2xl font-black">✓</div>
    <h1 class="mt-6 text-3xl font-black text-zinc-950">Bedankt voor je bericht!</h1>
    <p class="mt-3 text-zinc-500">We hebben je bericht ontvangen en nemen zo snel mogelijk contact op.</p>
    <div class="mt-8 flex justify-center gap-3 flex-wrap">
      <a href="/" class="inline-flex items-center bg-zinc-950 text-yellow-400 font-black px-6 py-2.5 text-sm hover:bg-zinc-800 transition-colors">Terug naar home</a>
      <a href="/oefenen/" class="inline-flex items-center border-2 border-zinc-900 text-zinc-900 font-bold px-6 py-2.5 text-sm hover:bg-zinc-900 hover:text-white transition-colors">Verder oefenen</a>
    </div>
  </Container>
</BaseLayout>
