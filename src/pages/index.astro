---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { SITE } from "@lib/site";

const categories = [
  { letter: "A", label: "Gevaarswaarschuwingsborden", desc: "Driehoekige borden met rode rand. Waarschuwen voor gevaarlijke situaties op de weg.", href: "/verkeersborden/#gevaarswaarschuwing", symbol: "▲", color: "text-red-400" },
  { letter: "B", label: "Voorrangsborden", desc: "Regelen wie voorrang heeft — haaienstanden, stopbord en voorrangsbord.", href: "/verkeersborden/#voorrang", symbol: "◆", color: "text-amber-400" },
  { letter: "C", label: "Verbodsborden", desc: "Ronde borden met rode rand. Verbieden inhalen, parkeren of bepaalde voertuigen.", href: "/verkeersborden/#verbod", symbol: "⊘", color: "text-rose-400" },
  { letter: "D", label: "Gebodsborden", desc: "Ronde blauwe borden. Schrijven voor wat je MOET doen: richting, rotonde, snelheid.", href: "/verkeersborden/#gebod", symbol: "●", color: "text-blue-400" },
  { letter: "E", label: "Aanwijzingsborden", desc: "Blauwe rechthoekige borden voor rijstroken, parkeren en fietsers.", href: "/verkeersborden/#aanwijzing", symbol: "▬", color: "text-sky-400" },
  { letter: "F", label: "Informatieborden", desc: "Geven aanvullende informatie: bebouwde kom, snelheidszones, parkeerinfo.", href: "/verkeersborden/#informatie", symbol: "ℹ", color: "text-zinc-400" },
];
---
<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description}>

  <!-- Hero: white, big typography, dark sign grid -->
  <section class="bg-white border-b border-zinc-100">
    <Container class="py-16 md:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block bg-yellow-400 text-zinc-900 text-xs font-black px-3 py-1 mb-6 uppercase tracking-wide">Gratis · geen account nodig</span>
          <h1 class="text-5xl sm:text-6xl font-black tracking-tight text-zinc-950 leading-none">
            Ken jij alle<br/>
            <span class="text-yellow-400">200+</span><br/>
            verkeers&shy;borden?
          </h1>
          <p class="mt-6 text-zinc-600 text-base max-w-md leading-relaxed">
            Er zijn meer dan 200 officiële Nederlandse verkeersborden. Leer ze herkennen en slaag voor je theorie-examen — gratis, direct, zonder account.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/oefenen/" class="inline-flex items-center bg-yellow-400 text-zinc-900 font-black px-6 py-3 text-sm hover:bg-yellow-300 transition-colors">
              Begin met oefenen →
            </a>
            <a href="/verkeersborden/" class="inline-flex items-center border-2 border-zinc-900 text-zinc-900 font-bold px-6 py-3 text-sm hover:bg-zinc-900 hover:text-white transition-colors">
              Alle categorieën
            </a>
          </div>
        </div>

        <!-- Dark sign tiles — 3×2 grid -->
        <div class="grid grid-cols-3 gap-2">
          {categories.map((cat) => (
            <a href={cat.href} class="group bg-zinc-950 flex flex-col items-center justify-center aspect-square hover:bg-zinc-800 transition-colors">
              <span class={`text-4xl leading-none ${cat.color}`}>{cat.symbol}</span>
              <span class="mt-2 text-yellow-400 font-black text-xs">{cat.letter}</span>
            </a>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Categories: stacked list, not card grid -->
  <Container class="py-(--spacing-section)">
    <div class="mb-8">
      <span class="text-xs font-black uppercase tracking-widest text-zinc-400">6 categorieën</span>
      <h2 class="text-3xl font-black text-zinc-950 mt-1">Welke borden zijn er?</h2>
    </div>
    <div class="divide-y divide-zinc-100 border-t border-b border-zinc-100">
      {categories.map((cat) => (
        <a href={cat.href} class="group flex items-start gap-5 py-5 hover:bg-zinc-50 -mx-4 px-4 transition-colors">
          <div class="shrink-0 w-10 h-10 bg-zinc-950 flex items-center justify-center">
            <span class="text-yellow-400 font-black text-sm">{cat.letter}</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-black text-zinc-900 group-hover:text-zinc-700">{cat.label}</div>
            <p class="text-sm text-zinc-500 mt-0.5 leading-relaxed">{cat.desc}</p>
          </div>
          <span class="shrink-0 text-zinc-200 group-hover:text-yellow-400 transition-colors text-xl font-light leading-none mt-1">→</span>
        </a>
      ))}
    </div>
    <div class="mt-6">
      <a href="/verkeersborden/" class="text-sm font-bold text-zinc-500 hover:text-zinc-900 transition-colors border-b border-zinc-300 hover:border-zinc-900 pb-0.5">
        Volledig overzicht met alle borden →
      </a>
    </div>
  </Container>

  <!-- How to practise: dark background -->
  <section class="bg-zinc-950 text-white">
    <Container class="py-(--spacing-section)">
      <div class="mb-12">
        <span class="text-xs font-black uppercase tracking-widest text-yellow-400">Aanpak</span>
        <h2 class="text-3xl font-black text-white mt-1">Zo oefen je slim</h2>
      </div>
      <div class="grid gap-10 sm:grid-cols-3">
        {[
          { n: "01", title: "Leer de systematiek", body: "Elke categorie heeft een eigen vorm en kleur. Driehoek + rood = gevaar. Cirkel + rood = verbod. Cirkel + blauw = gebod. Die logica dekt 80% van alle borden." },
          { n: "02", title: "Focus op het examen", body: "C6, C11, D1, D4, B6, B7 — dit zijn de borden die het vaakst terugkomen op het CBR examen. Begin hier, ga daarna verder." },
          { n: "03", title: "Train visuele herkenning", body: "Op het examen zie je een afbeelding, geen omschrijving. Oefen borden visueel herkennen — niet nummercodes uit je hoofd leren." },
        ].map(({ n, title, body }) => (
          <div>
            <div class="text-6xl font-black text-yellow-400 leading-none mb-5 opacity-80">{n}</div>
            <h3 class="font-black text-white mb-2">{title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 pt-8 border-t border-zinc-800">
        <a href="/oefenen/" class="inline-flex items-center bg-yellow-400 text-zinc-900 font-black px-6 py-3 text-sm hover:bg-yellow-300 transition-colors">
          Bekijk de volledige oefenstrategie →
        </a>
      </div>
    </Container>
  </section>

  <!-- FAQ -->
  <Container class="max-w-2xl py-(--spacing-section)">
    <div class="mb-8">
      <span class="text-xs font-black uppercase tracking-widest text-zinc-400">Vragen</span>
      <h2 class="text-3xl font-black text-zinc-950 mt-1">Veelgestelde vragen</h2>
    </div>
    <div class="divide-y divide-zinc-100 border-t border-zinc-100">
      {[
        { q: "Hoeveel verkeersborden zijn er in Nederland?", a: "Er zijn meer dan 200 officiële Nederlandse verkeersborden, ingedeeld in categorieën A t/m G. Voor het theorie-examen moet je de meest voorkomende borden kunnen herkennen." },
        { q: "Welke borden komen het meest voor op het examen?", a: "Verbodsborden (C), gebodsborden (D) en gevaarswaarschuwingsborden (A) komen het meest voor. Ook voorrangssituaties met het stopbord (B6) en verleen voorrang (B7) zijn examenfavoriet." },
        { q: "Hoe herken ik snel wat een bord betekent?", a: "Gebruik de vorm en kleur als eerste aanwijzing. Driehoek met rode rand = gevaar. Rode cirkel = verbod. Blauwe cirkel = gebod. Die basisregel dekt al 80% van de borden." },
        { q: "Moet ik alle borden uit mijn hoofd leren?", a: "Niet per se. Focus op de meest voorkomende borden en leer de systematiek van de categorieën. Als je de logica begrijpt, kun je ook onbekende borden redeneren." },
        { q: "Zijn de borden hetzelfde als in België of Duitsland?", a: "Grotendeels wel — veel borden zijn gebaseerd op Europese verdragen. Er zijn kleine regionale verschillen, maar de basiscategorieën zijn in heel Europa hetzelfde." },
      ].map(({ q, a }) => (
        <details class="group">
          <summary class="flex cursor-pointer items-center justify-between py-4 text-sm font-bold text-zinc-900 list-none gap-4 hover:text-zinc-600 transition-colors">
            {q}
            <span class="text-xl font-light text-zinc-300 group-open:rotate-45 transition-transform shrink-0 leading-none">+</span>
          </summary>
          <p class="pb-5 text-sm text-zinc-500 leading-relaxed">{a}</p>
        </details>
      ))}
    </div>
  </Container>

  <!-- CTA: yellow band -->
  <section class="bg-yellow-400">
    <Container class="py-12 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-xs font-black uppercase tracking-widest text-yellow-700 mb-1">Gratis · geen account nodig</p>
        <h2 class="text-2xl font-black text-zinc-900">Klaar om te beginnen?</h2>
        <p class="text-zinc-700 text-sm mt-1">Ken alle verkeersborden en slaag voor je theorie-examen.</p>
      </div>
      <a href="/oefenen/" class="shrink-0 inline-flex items-center bg-zinc-950 text-yellow-400 font-black px-7 py-3 hover:bg-zinc-800 transition-colors text-sm">
        Begin nu gratis →
      </a>
    </Container>
  </section>

</BaseLayout>
