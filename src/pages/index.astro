---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { SITE } from "@lib/site";

const categories = [
  {
    id: "gevaarswaarschuwing",
    label: "A — Gevaar",
    title: "Gevaarswaarschuwingsborden",
    desc: "Driehoekige borden met rode rand. Waarschuwen voor gevaarlijke situaties op de weg.",
    shape: "▲",
    bg: "bg-red-50",
    border: "border-red-200",
    accent: "text-red-600",
  },
  {
    id: "voorrang",
    label: "B — Voorrang",
    title: "Voorrangsborden",
    desc: "Regelen wie voorrang heeft. Denk aan de haaienstanden, het stopbord en het voorrangsbord.",
    shape: "◆",
    bg: "bg-amber-50",
    border: "border-amber-200",
    accent: "text-amber-700",
  },
  {
    id: "verbod",
    label: "C — Verbod",
    title: "Verbodsborden",
    desc: "Ronde borden met rode rand. Verbieden bepaald gedrag: inhalen, parkeren, bepaalde voertuigen.",
    shape: "⊘",
    bg: "bg-rose-50",
    border: "border-rose-200",
    accent: "text-rose-600",
  },
  {
    id: "gebod",
    label: "D — Gebod",
    title: "Gebodsborden",
    desc: "Ronde blauwe borden. Schrijven voor wat je MOET doen: rechts houden, doorrijden, snelheid.",
    shape: "●",
    bg: "bg-blue-50",
    border: "border-blue-200",
    accent: "text-blue-600",
  },
  {
    id: "aanwijzing",
    label: "E — Aanwijzing",
    title: "Aanwijzingsborden",
    desc: "Blauwe rechthoekige borden voor rijstroken, parkeren, voetgangers en fietsers.",
    shape: "▬",
    bg: "bg-sky-50",
    border: "border-sky-200",
    accent: "text-sky-600",
  },
  {
    id: "informatie",
    label: "F — Informatie",
    title: "Informatieborden",
    desc: "Geven aanvullende informatie: bebouwde kom, snelheidszones, parkeerinfo en meer.",
    shape: "ℹ",
    bg: "bg-green-50",
    border: "border-green-200",
    accent: "text-green-700",
  },
];
---
<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description}>

  <!-- Hero -->
  <section class="bg-green-700 text-white overflow-hidden">
    <Container class="py-16 md:py-24">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-green-600/60 border border-green-500/40 rounded-full px-4 py-1.5 text-xs font-semibold text-green-100 mb-6">
          🆓 Gratis oefenen — geen account nodig
        </div>
        <h1 class="text-5xl font-black tracking-tight leading-tight sm:text-6xl">
          Ken jij alle<br/>
          <span class="text-amber-300">verkeersborden?</span>
        </h1>
        <p class="mt-5 text-green-100 text-lg max-w-lg leading-relaxed">
          Er zijn meer dan 200 officiële Nederlandse verkeersborden. Herken ze allemaal en slaag voor je theorie-examen.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/oefenen/" class="inline-flex items-center gap-2 bg-amber-400 text-gray-900 font-black px-6 py-3 rounded-full text-sm hover:bg-amber-300 transition-colors shadow-sm">
            Begin met oefenen →
          </a>
          <a href="/verkeersborden/" class="inline-flex items-center gap-2 border border-green-500 text-green-100 hover:text-white hover:border-green-400 font-semibold px-6 py-3 rounded-full text-sm transition-colors">
            Alle categorieën
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-12">
        {[
          { v: "200+", l: "Verkeersborden" },
          { v: "6", l: "Categorieën" },
          { v: "65", l: "Examenvragen" },
          { v: "100%", l: "Gratis" },
        ].map(({ v, l }) => (
          <div class="bg-green-600/50 border border-green-500/30 rounded-xl px-4 py-3">
            <div class="text-2xl font-black text-white">{v}</div>
            <div class="text-xs text-green-200 mt-0.5">{l}</div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Sign categories -->
  <Container class="py-(--spacing-section)">
    <div class="text-center mb-10">
      <p class="text-xs font-bold uppercase tracking-widest text-green-600 mb-2">Categorieën</p>
      <h2 class="text-3xl font-black text-gray-900">Alle soorten verkeersborden</h2>
      <p class="mt-2 text-gray-500 max-w-xl mx-auto text-sm">Elke categorie heeft een eigen vorm en kleur zodat je borden snel herkent.</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <a href={`/verkeersborden/#${cat.id}`}
           class={`group flex flex-col rounded-2xl border ${cat.border} ${cat.bg} p-5 hover:shadow-md transition-all`}>
          <div class="flex items-center justify-between mb-4">
            <span class={`text-xs font-bold ${cat.accent} uppercase tracking-wider`}>{cat.label}</span>
            <span class={`text-2xl ${cat.accent} opacity-50 group-hover:opacity-100 transition-opacity`}>{cat.shape}</span>
          </div>
          <h3 class="font-black text-gray-900 mb-1.5">{cat.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed flex-1">{cat.desc}</p>
          <span class={`mt-4 text-xs font-bold ${cat.accent}`}>Bekijken →</span>
        </a>
      ))}
    </div>
  </Container>

  <!-- How to practise -->
  <section class="bg-stone-50 border-y border-stone-200">
    <Container class="py-(--spacing-section)">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-green-600 mb-2">Aanpak</p>
        <h2 class="text-3xl font-black text-gray-900">Zo oefen je slim</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-3 max-w-4xl mx-auto">
        {[
          { n: "1", icon: "📋", title: "Leer de categorieën", body: "Begin met de zes categorieën. Elke categorie heeft een eigen vorm en kleur — dat maakt herkennen veel makkelijker." },
          { n: "2", icon: "🔁", title: "Oefen per categorie", body: "Focus eerst op de meest voorkomende borden: verbod, gebod en gevaarswaarschuwing. Die komen het vaakst voor op het examen." },
          { n: "3", icon: "✅", title: "Test jezelf", body: "Train herkenning door borden door elkaar te oefenen, precies zoals op het echte theorie-examen." },
        ].map(({ n, icon, title, body }) => (
          <div class="bg-white rounded-2xl p-6 border border-stone-200 shadow-sm relative overflow-hidden">
            <div class="text-3xl mb-3">{icon}</div>
            <div class="absolute top-4 right-4 text-5xl font-black text-stone-100 leading-none select-none">{n}</div>
            <h3 class="font-black text-gray-900 mb-2">{title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/oefenen/" class="inline-flex items-center bg-green-700 hover:bg-green-800 text-white font-bold px-7 py-3 rounded-full text-sm transition-colors">
          Direct oefenen →
        </a>
      </div>
    </Container>
  </section>

  <!-- FAQ -->
  <Container class="max-w-2xl py-(--spacing-section)">
    <div class="text-center mb-8">
      <p class="text-xs font-bold uppercase tracking-widest text-green-600 mb-2">Veelgestelde vragen</p>
      <h2 class="text-3xl font-black text-gray-900">Vragen over verkeersborden</h2>
    </div>
    <div class="space-y-3">
      {[
        { q: "Hoeveel verkeersborden zijn er in Nederland?", a: "Er zijn meer dan 200 officiële Nederlandse verkeersborden, ingedeeld in categorieën A t/m G. Voor het theorie-examen moet je de meest voorkomende borden kunnen herkennen." },
        { q: "Welke verkeersborden komen het meest voor op het examen?", a: "Verbodsborden (C), gebodsborden (D) en gevaarswaarschuwingsborden (A) komen het meest voor. Ook voorrangssituaties met het stopbord (B6) en verleen voorrang (B7) zijn examenfavoriet." },
        { q: "Hoe herken ik snel wat een bord betekent?", a: "Gebruik de vorm en kleur als eerste aanwijzing. Driehoek met rode rand = gevaar. Rode cirkel = verbod. Blauwe cirkel = gebod. Blauw rechthoek = aanwijzing. Die basisregel dekt al 80% van de borden." },
        { q: "Moet ik alle borden uit mijn hoofd leren?", a: "Niet per se. Focus op de meest voorkomende borden en leer de systematiek van de categorieën. Als je de logica begrijpt, kun je ook onbekende borden redeneren." },
        { q: "Zijn de borden hetzelfde als in België of Duitsland?", a: "Grotendeels wel — veel borden zijn gebaseerd op Europese verdragen. Er zijn kleine regionale verschillen, maar de basiscategorieën en -vormen zijn in heel Europa hetzelfde." },
      ].map(({ q, a }) => (
        <details class="group bg-white rounded-2xl border border-gray-100 hover:border-green-200 transition-colors overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between px-5 py-4 text-sm font-semibold text-gray-900 list-none gap-4">
            {q}
            <span class="text-xl font-light text-green-500 group-open:rotate-45 transition-transform shrink-0 leading-none">+</span>
          </summary>
          <p class="px-5 pb-5 text-sm text-gray-500 leading-relaxed">{a}</p>
        </details>
      ))}
    </div>
  </Container>

  <!-- CTA -->
  <section class="bg-green-700 text-white">
    <Container class="py-14 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-green-300 mb-1">Gratis · geen account</p>
        <h2 class="text-2xl font-black">Klaar om te oefenen?</h2>
        <p class="text-green-100 text-sm mt-1">Ken alle verkeersborden en slaag voor je theorie-examen.</p>
      </div>
      <a href="/oefenen/" class="shrink-0 inline-flex items-center gap-2 bg-amber-400 text-gray-900 font-black px-7 py-3 rounded-full hover:bg-amber-300 transition-colors text-sm shadow-sm">
        Begin nu gratis →
      </a>
    </Container>
  </section>

</BaseLayout>
