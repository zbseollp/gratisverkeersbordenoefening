---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";

const main = [
  { href: "/", title: "Home" },
  { href: "/oefenen/", title: "Oefenen" },
  { href: "/verkeersborden/", title: "Verkeersborden" },
  { href: "/over-ons/", title: "Over ons" },
  { href: "/contact/", title: "Contact" },
];
---
<BaseLayout title="Sitemap | GratisVerkeersbordenOefening" description="Overzicht van alle pagina's op GratisVerkeersbordenOefening.">
  <div class="bg-green-700 text-white">
    <Container class="py-10">
      <h1 class="text-4xl font-black tracking-tight">Sitemap</h1>
    </Container>
  </div>

  <Container class="py-(--spacing-section)">
    <section>
      <h2 class="text-xl font-black text-gray-900 mb-4">Pagina's</h2>
      <ul class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
        {main.map((p) => <li><a class="text-green-700 hover:underline" href={p.href}>{p.title}</a></li>)}
      </ul>
    </section>
  </Container>
</BaseLayout>
