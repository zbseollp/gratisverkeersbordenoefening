---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
---
<BaseLayout title="Pagina niet gevonden (404) | GratisVerkeersbordenOefening" description="Deze pagina bestaat niet." noindex={true}>
  <Container class="max-w-2xl py-(--spacing-section) text-center">
    <p class="text-7xl font-black text-green-600">404</p>
    <h1 class="mt-4 text-3xl font-black text-gray-900">Pagina niet gevonden</h1>
    <p class="mt-3 text-gray-600">Oeps — deze pagina bestaat niet (meer). Ga terug naar home of bekijk alle verkeersborden.</p>
    <div class="mt-8 flex justify-center gap-3 flex-wrap">
      <a href="/" class="inline-flex items-center rounded-full bg-green-700 px-6 py-2.5 text-sm font-bold text-white hover:bg-green-800 transition-colors">Naar home</a>
      <a href="/verkeersborden/" class="inline-flex items-center rounded-full border border-green-200 bg-green-50 px-6 py-2.5 text-sm font-bold text-green-700 hover:bg-green-100 transition-colors">Alle verkeersborden</a>
    </div>
  </Container>
</BaseLayout>
