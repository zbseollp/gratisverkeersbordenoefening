---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
---
<BaseLayout title="Pagina niet gevonden (404) | GratisVerkeersbordenOefening" description="Deze pagina bestaat niet." noindex={true}>
  <Container class="max-w-2xl py-(--spacing-section) text-center">
    <p class="text-8xl font-black text-yellow-400 leading-none">404</p>
    <h1 class="mt-4 text-3xl font-black text-zinc-950">Pagina niet gevonden</h1>
    <p class="mt-3 text-zinc-500">Oeps, deze pagina bestaat niet (meer). Ga terug naar home of bekijk alle verkeersborden.</p>
    <div class="mt-8 flex justify-center gap-3 flex-wrap">
      <a href="/" class="inline-flex items-center bg-zinc-950 text-yellow-400 font-black px-6 py-2.5 text-sm hover:bg-zinc-800 transition-colors">Naar home</a>
      <a href="/verkeersborden/" class="inline-flex items-center border-2 border-zinc-900 text-zinc-900 font-bold px-6 py-2.5 text-sm hover:bg-zinc-900 hover:text-white transition-colors">Alle verkeersborden</a>
    </div>
  </Container>
</BaseLayout>
